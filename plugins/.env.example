# LaraPaper Publishing Configuration
# Copy this file to .env and fill in your values

# LaraPaper instance URL (no trailing slash)
LARAPAPER_URL=https://your-larapaper-instance.com

# API token from LaraPaper (get from /plugins/api page)
# Login to LaraPaper → Plugins & Recipes → API tab → copy token
LARAPAPER_TOKEN=your-api-token-here
