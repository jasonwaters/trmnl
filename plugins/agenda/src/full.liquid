{% assign view_mode = trmnl.plugin_settings.custom_fields_values.view_mode | default: "basic_list" %}
{% assign today_label = generated_at | default: "now" | date: "%a, %b %-d" %}
{% assign calendar_title = calendar_name | default: "Agenda" %}

{% if view_mode == 'basic_list' %}
<!-- ============================================================================ -->
<!-- Basic List Mode - TRMNL Framework Components -->
<!-- ============================================================================ -->

<style media="screen">
  .agenda-list {
    padding: 12px;
    justify-content: flex-start !important;
    align-items: stretch !important;
  }

  .agenda-item {
    margin-bottom: 8px;
  }

  .agenda-item:last-child {
    margin-bottom: 0;
  }

  .agenda-item .content {
    min-width: 0;
  }

  .agenda-time {
    white-space: nowrap;
  }
</style>

<div class="view view--full">
<div class="layout layout--col layout--top agenda-list">
  {% assign window_start_date = generated_at | default: "now" | date: "%Y-%m-%d" %}
  {% assign window_start_epoch = generated_at | default: "now" | date: "%s" %}
  {% assign window_end_epoch = window_start_epoch | plus: 604800 %}
  {% assign window_end_date = window_end_epoch | date: "%Y-%m-%d" %}
  {% assign last_rendered_date = "" %}
  {% assign displayed_count = 0 %}
  {% assign sources = events | map: "source" | uniq %}

  {% for event in events %}
        {% if event.start_date > window_end_date %}
          {% break %}
        {% endif %}
        {% assign overlaps_window = false %}
        {% if event.end_date >= window_start_date and event.start_date <= window_end_date %}
          {% assign overlaps_window = true %}
        {% endif %}
        {% if overlaps_window %}
          {% assign display_date = event.start_date %}
          {% if event.start_date < window_start_date %}
            {% assign display_date = window_start_date %}
          {% endif %}
          {% assign displayed_count = displayed_count | plus: 1 %}
          {% if display_date != last_rendered_date %}
            {% assign last_rendered_date = display_date %}
            <span class="label label--small label--underline">{{ display_date | date: "%A, %B %-d, %Y" }}</span>
          {% endif %}
        {% else %}
          {% continue %}
        {% endif %}
        {% assign source_index = 0 %}
        {% for source in sources %}
          {% if source == event.source %}
            {% assign source_index = forloop.index %}
            {% break %}
          {% endif %}
        {% endfor %}
        {% assign emphasis_level = source_index | modulo: 3 | plus: 1 %}

        <div class="item agenda-item item--emphasis-{{ emphasis_level }}">
          <div class="meta"></div>
          <div class="content">
            <span class="title title--small">{{ event.summary | default: "Untitled event" }}</span>
            {% if event.description and event.description != "" %}
              <span class="description" data-clamp="2">{{ event.description }}</span>
            {% endif %}

            <div class="flex gap--small">
              {% if event.all_day %}
                <span class="label label--small label--underline">All Day</span>
              {% else %}
                <span
                  class="label label--small label--underline agenda-time js-local-time"
                  data-start="{{ event.start }}"
                  data-end="{{ event.end }}"
                >
                  {{ event.start }} - {{ event.end }}
                </span>
              {% endif %}

              <span class="label label--small label--underline">{{ event.start | date: "%a %b %-d" }}</span>

              {% if event.source %}
                <span class="label label--small label--underline">{{ event.source }}</span>
              {% endif %}
            </div>
          </div>
        </div>
  {% endfor %}

  {% if displayed_count == 0 %}
    <div class="item agenda-item">
      <div class="meta"></div>
      <div class="content">
        <span class="title title--small">No events in the next 7 days</span>
        <span class="description">Your schedule is clear.</span>
      </div>
    </div>
  {% endif %}
</div>
<div class="title_bar">
  <span class="title">{{ calendar_title }}</span>
  <span class="instance">{{ today_label }}</span>
</div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var timeElements = document.querySelectorAll('.js-local-time');
    timeElements.forEach(function(el) {
      var startIso = el.getAttribute('data-start');
      var endIso = el.getAttribute('data-end');
      if (!startIso || !endIso) return;

      var startDate = new Date(startIso);
      var endDate = new Date(endIso);
      if (isNaN(startDate.getTime()) || isNaN(endDate.getTime())) return;

      var startText = startDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
      var endText = endDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
      el.textContent = startText + ' - ' + endText;
    });
  });
</script>

{% else %}
<!-- ============================================================================ -->
<!-- Day / List Mode - SimpleCalendarJS -->
<!-- ============================================================================ -->

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;700&display=swap">
<link rel="stylesheet" href="https://unpkg.com/simple-calendar-js/dist/simple-calendar-js.min.css">
<script src="https://unpkg.com/simple-calendar-js/dist/simple-calendar-js.min.js"></script>

<style media="screen">
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    width: 100%;
    overflow: hidden;
  }

  #calendar-agenda {
    height: 100%;
    width: 100%;
  }

  #calendar-agenda * {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 12px;
    line-height: 1.3;
  }

  /* Server-driven list mode (timezone-safe date grouping) */
  #calendar-agenda .agenda-server-list {
    height: 100%;
    overflow: hidden;
    padding: 6px 0;
  }

  #calendar-agenda .agenda-server-date {
    font-weight: 700;
    font-size: 13px;
    border-bottom: 1px solid #d8d8d8;
    padding: 6px 8px;
    margin-top: 2px;
  }

  #calendar-agenda .agenda-server-row {
    display: grid;
    grid-template-columns: 10px 96px 1fr;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-bottom: 1px solid #e6e6e6;
  }

  #calendar-agenda .agenda-server-dot {
    font-size: 10px;
    line-height: 1;
  }

  #calendar-agenda .agenda-server-time {
    font-size: 12px;
    white-space: nowrap;
  }

  #calendar-agenda .agenda-server-title {
    font-size: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Day view - e-ink styling */
  #calendar-agenda .sc-event {
    border-radius: 0 !important;
    overflow: visible !important;
    padding: 2px 4px !important;
  }

  #calendar-agenda .sc-event-title {
    display: block !important;
    font-size: 11px !important;
    line-height: 1.2 !important;
    overflow: visible !important;
  }

  #calendar-agenda .sc-event-time {
    font-size: 10px !important;
  }

  /* List view - e-ink styling */
  #calendar-agenda .sc-list-event {
    border-left: 4px solid black;
    padding: 8px;
    margin-bottom: 4px;
    background-color: white;
  }

  #calendar-agenda .sc-list-event-title {
    font-weight: 700;
    margin-bottom: 4px;
  }

  #calendar-agenda .sc-list-event-time {
    font-size: 11px;
    opacity: 0.8;
  }

  #calendar-agenda .sc-list-date-header {
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    margin: 12px 0 8px 0;
    padding-bottom: 4px;
    border-bottom: 2px solid black;
  }

  /* Time slots */
  #calendar-agenda .sc-time-slot {
    border: 1px dashed rgba(0, 0, 0, 0.2) !important;
  }

  /* Current time indicator */
  #calendar-agenda .sc-current-time {
    border-top: 2px solid black !important;
  }

  /* Day header */
  #calendar-agenda .sc-header-cell {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
  }

  /* Time column */
  #calendar-agenda .sc-time-col {
    font-size: 11px;
    font-weight: 700;
  }

  /* Hide toolbar */
  #calendar-agenda .sc-toolbar {
    display: none !important;
  }

  /* Remove scrollbars */
  #calendar-agenda .sc-scroller,
  #calendar-agenda .sc-body {
    overflow: hidden !important;
  }

  /* Force day view to fill height */
  #calendar-agenda .sc-day-view,
  #calendar-agenda .sc-list-view,
  #calendar-agenda .sc-view-container,
  #calendar-agenda .sc-container {
    height: 100% !important;
    max-height: none !important;
    min-height: 100vh !important;
  }
</style>

<div class="view view--full">
  <div class="layout layout--col layout--top">
    <div id="calendar-agenda"></div>
  </div>
  {% if view_mode == 'list' %}
  <div class="title_bar">
    <span class="title">{{ calendar_title }}</span>
    <span class="instance">{{ today_label }}</span>
  </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var VIEW_MODE = '{{ view_mode }}';

    function escapeHtml(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function parseServerDate(serverDate) {
      if (!serverDate) return null;
      var parts = serverDate.split('-');
      if (parts.length !== 3) return null;
      return new Date(parseInt(parts[0], 10), parseInt(parts[1], 10) - 1, parseInt(parts[2], 10));
    }

    function formatServerDate(serverDate) {
      var parsed = parseServerDate(serverDate);
      if (!parsed) return serverDate || '';
      return parsed.toLocaleDateString('en-US', {
        weekday: 'long',
        month: 'long',
        day: 'numeric',
        year: 'numeric'
      });
    }

    function toServerAnchoredDate(serverDate, originalIso) {
      if (!serverDate || !originalIso) return new Date(originalIso);
      var original = new Date(originalIso);
      var parts = serverDate.split('-');
      if (parts.length !== 3) return original;
      var year = parseInt(parts[0], 10);
      var month = parseInt(parts[1], 10) - 1;
      var day = parseInt(parts[2], 10);
      // Build with numeric constructor to avoid timezone parsing drift.
      var anchored = new Date(
        year,
        month,
        day,
        original.getHours(),
        original.getMinutes(),
        original.getSeconds(),
        0
      );
      return anchored;
    }

    var rawEvents = [
      {% for event in events %}
      {
        id: {{ event.uid | json }},
        title: {{ event.summary | default: "Untitled event" | json }},
        startIso: {{ event.start | json }},
        endIso: {{ event.end | json }},
        startDate: {{ event.start_date | json }},
        endDate: {{ event.end_date | json }},
        allDay: {{ event.all_day }},
        source: {{ event.source | default: "default" | json }}
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];

    if (VIEW_MODE === 'list') {
      var container = document.getElementById('calendar-agenda');
      var eventsByDate = new Map();
      var windowStartDate = '{{ generated_at | default: "now" | date: "%Y-%m-%d" }}';
      var windowStart = parseServerDate(windowStartDate);
      var windowEnd = new Date(windowStart);
      windowEnd.setDate(windowEnd.getDate() + 7);
      var windowEndKey =
        windowEnd.getFullYear() +
        '-' +
        String(windowEnd.getMonth() + 1).padStart(2, '0') +
        '-' +
        String(windowEnd.getDate()).padStart(2, '0');

      rawEvents.forEach(function(event) {
        if (!event.startDate || !event.endDate) {
          return;
        }
        if (event.endDate < windowStartDate || event.startDate > windowEndKey) {
          return;
        }
        var key = event.startDate < windowStartDate ? windowStartDate : event.startDate;
        if (!eventsByDate.has(key)) {
          eventsByDate.set(key, []);
        }
        eventsByDate.get(key).push(event);
      });

      var sortedDates = Array.from(eventsByDate.keys()).sort();
      var html = '<div class="agenda-server-list">';

      sortedDates.forEach(function(dateKey) {
        var groupedEvents = eventsByDate.get(dateKey) || [];
        groupedEvents.sort(function(a, b) {
          return new Date(a.startIso) - new Date(b.startIso);
        });

        html += '<div class="agenda-server-date">' + escapeHtml(formatServerDate(dateKey)) + '</div>';

        groupedEvents.forEach(function(event) {
          var timeLabel = 'All Day';
          if (!event.allDay) {
            var startTime = new Date(event.startIso).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
            var endTime = new Date(event.endIso).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
            timeLabel = startTime + ' - ' + endTime;
          }

          html += '<div class="agenda-server-row">' +
            '<span class="agenda-server-dot">●</span>' +
            '<span class="agenda-server-time">' + escapeHtml(timeLabel) + '</span>' +
            '<span class="agenda-server-title">' + escapeHtml(event.title) + '</span>' +
            '</div>';
        });
      });

      html += '</div>';
      container.innerHTML = html;
      return;
    }

    var eventsData = [
      {% for event in events %}
      {
        id: '{{ event.uid }}',
        title: '{{ event.summary }}',
        start: toServerAnchoredDate('{{ event.start_date }}', '{{ event.start }}'),
        end: toServerAnchoredDate('{{ event.end_date }}', '{{ event.end }}'),
        allDay: {{ event.all_day }},
        source: '{{ event.source | default: "default" }}'
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];

    var sources = [...new Set(eventsData.map(e => e.source))];
    var sourceColors = {};
    var sourceTextColors = {};

    var colorPatterns = [
      ['#000000', '#ffffff'],
      ['#cccccc', '#000000'],
      ['#333333', '#ffffff'],
      ['#e6e6e6', '#000000']
    ];

    sources.forEach(function(source, i) {
      var pattern = colorPatterns[i % colorPatterns.length];
      sourceColors[source] = pattern[0];
      sourceTextColors[source] = pattern[1];
    });

    eventsData.forEach(function(event) {
      event.color = sourceColors[event.source] || '#000000';
      event.textColor = sourceTextColors[event.source] || '#ffffff';
    });

    var fetchEventsFunc;
    if (VIEW_MODE === 'day') {
      fetchEventsFunc = function(start, end) {
        var today = new Date();
        today.setHours(0, 0, 0, 0);
        var tomorrow = new Date(today);
        tomorrow.setDate(tomorrow.getDate() + 1);

        return eventsData.filter(function(e) {
          return e.start >= today && e.start < tomorrow;
        });
      };
    } else {
      fetchEventsFunc = function(start, end) {
        var today = new Date();
        today.setHours(0, 0, 0, 0);

        return eventsData.filter(function(e) {
          return e.start >= today;
        }).slice(0, 15);
      };
    }

    var calendar = new SimpleCalendarJs('#calendar-agenda', {
      defaultView: VIEW_MODE,
      weekStartsOn: 0,
      use24Hour: false,
      showToolbar: false,
      showTodayButton: false,
      showNavigation: false,
      showViewSwitcher: false,
      showYearPicker: false,
      showTooltips: false,
      showGridLines: true,
      showBorder: false,
      enableDragDrop: false,
      enableResize: false,
      listDaysForward: 7,
      fetchEvents: fetchEventsFunc
    });
  });
</script>

{% endif %}
