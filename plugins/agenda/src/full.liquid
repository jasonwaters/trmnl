{% assign view_mode = trmnl.plugin_settings.custom_fields_values.view_mode | default: "basic_list" %}
{% assign today_label = agenda_today_label %}
{% assign calendar_title = calendar_name | default: "Agenda" %}

{% if view_mode == 'basic_list' %}
<!-- ============================================================================ -->
<!-- Basic List Mode - TRMNL Framework Components -->
<!-- ============================================================================ -->

<style media="screen">
  .agenda-list {
    padding: 12px;
    justify-content: flex-start !important;
    align-items: stretch !important;
  }

  .agenda-item {
    margin-bottom: 8px;
  }

  .agenda-item:last-child {
    margin-bottom: 0;
  }

  .agenda-item .content {
    min-width: 0;
  }

  .agenda-time {
    white-space: nowrap;
  }
</style>

<div class="view view--full">
<div class="layout layout--col layout--top agenda-list">
  {% assign window_start_date = agenda_today_local_date %}
  {% assign window_start_epoch = agenda_now_local_epoch %}
  {% assign window_end_epoch = window_start_epoch | plus: 604800 %}
  {% assign window_end_date = window_end_epoch | date: "%Y-%m-%d" %}
  {% assign last_rendered_date = "" %}
  {% assign displayed_count = 0 %}
  {% assign sources = events | map: "source" | uniq %}

  {% for event in events %}
        {% if event.start_date > window_end_date %}
          {% break %}
        {% endif %}
        {% assign event_end_epoch = event.end | date: "%s" | plus: 0 %}
        {% if event_end_epoch <= agenda_now_utc_epoch %}
          {% continue %}
        {% endif %}
        {% assign overlaps_window = false %}
        {% if event.all_day %}
          {% if event.end_date > window_start_date and event.start_date <= window_end_date %}
            {% assign overlaps_window = true %}
          {% endif %}
        {% else %}
          {% if event.end_date >= window_start_date and event.start_date <= window_end_date %}
            {% assign overlaps_window = true %}
          {% endif %}
        {% endif %}
        {% if overlaps_window %}
          {% assign display_date = event.start_date %}
          {% if event.start_date < window_start_date %}
            {% assign display_date = window_start_date %}
          {% endif %}
          {% assign displayed_count = displayed_count | plus: 1 %}
          {% if display_date != last_rendered_date %}
            {% assign last_rendered_date = display_date %}
            <span class="{{ agenda_label_class }}">{{ display_date | date: "%A, %B %-d, %Y" }}</span>
          {% endif %}
        {% else %}
          {% continue %}
        {% endif %}
        {% assign source_index = 0 %}
        {% for source in sources %}
          {% if source == event.source %}
            {% assign source_index = forloop.index %}
            {% break %}
          {% endif %}
        {% endfor %}
        {% assign emphasis_level = source_index | modulo: 3 | plus: 1 %}

        <div class="item agenda-item item--emphasis-{{ emphasis_level }}">
          <div class="meta"></div>
          <div class="content">
            <span class="{{ agenda_title_class }}">{{ event.summary | default: "Untitled event" }}</span>
            {% if show_event_descriptions and event.description and event.description != "" %}
              <span class="description" data-clamp="2">{{ event.description }}</span>
            {% endif %}

            <div class="flex gap--small">
              {% if event.all_day %}
                <span class="{{ agenda_label_class }}">All Day</span>
              {% else %}
                {% assign start_local_epoch = event.start | date: "%s" | plus: effective_utc_offset %}
                {% assign end_local_epoch = event.end | date: "%s" | plus: effective_utc_offset %}
                {% assign display_start = start_local_epoch | date: "%-I:%M %p" %}
                {% assign display_end = end_local_epoch | date: "%-I:%M %p" %}
                <span
                  class="{{ agenda_label_class }} agenda-time"
                >
                  {{ display_start }} - {{ display_end }}
                </span>
              {% endif %}

            </div>
          </div>
        </div>
  {% endfor %}

  {% if displayed_count == 0 %}
    <div class="item agenda-item">
      <div class="meta"></div>
      <div class="content">
        <span class="{{ agenda_title_class }}">No events in the next 7 days</span>
        <span class="description">Your schedule is clear.</span>
      </div>
    </div>
  {% endif %}
</div>
<div class="title_bar">
  <span class="title">{{ calendar_title }}</span>
  <span class="instance">{{ today_label }}</span>
</div>
</div>

{% else %}
<!-- ============================================================================ -->
<!-- Day / List Mode - SimpleCalendarJS -->
<!-- ============================================================================ -->

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;700&display=swap">
<link rel="stylesheet" href="https://unpkg.com/simple-calendar-js/dist/simple-calendar-js.min.css">
<script src="https://unpkg.com/simple-calendar-js/dist/simple-calendar-js.min.js"></script>

<style media="screen">
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    width: 100%;
    overflow: hidden;
  }

  #calendar-agenda {
    height: 100%;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
  }

  #calendar-agenda * {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 12px;
    line-height: 1.3;
  }

  /* Day view - e-ink styling */
  #calendar-agenda .sc-event {
    border-radius: 0 !important;
    overflow: visible !important;
    padding: 2px 4px !important;
  }

  #calendar-agenda .sc-event-title {
    display: block !important;
    font-size: 11px !important;
    line-height: 1.2 !important;
    overflow: visible !important;
  }

  #calendar-agenda .sc-event-time {
    font-size: 10px !important;
  }

  /* List view - e-ink styling */
  #calendar-agenda .sc-list-event {
    border-left: 4px solid black;
    padding: 8px;
    margin-bottom: 4px;
    background-color: white;
  }

  #calendar-agenda .sc-list-event-title {
    font-weight: 700;
    margin-bottom: 4px;
  }

  #calendar-agenda .sc-list-event-time {
    font-size: 11px;
    opacity: 0.8;
  }

  #calendar-agenda .sc-list-date-header {
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    margin: 12px 0 8px 0;
    padding-bottom: 4px;
    border-bottom: 2px solid black;
  }

  /* Time slots */
  #calendar-agenda .sc-time-slot {
    border: 1px dashed rgba(0, 0, 0, 0.2) !important;
  }

  /* Current time indicator */
  #calendar-agenda .sc-current-time {
    border-top: 2px solid black !important;
  }

  /* Day header */
  #calendar-agenda .sc-header-cell {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
  }

  /* Time column */
  #calendar-agenda .sc-time-col {
    font-size: 11px;
    font-weight: 700;
  }

  /* Hide toolbar */
  #calendar-agenda .sc-toolbar {
    display: none !important;
  }

  /* Hide current time indicator */
  #calendar-agenda .uc-now-indicator,
  #calendar-agenda .uc-now-dot,
  #calendar-agenda .uc-now-line {
    display: none !important;
  }

  /* Remove scrollbars */
  #calendar-agenda .sc-scroller,
  #calendar-agenda .sc-body,
  #calendar-agenda .sc-list-view,
  #calendar-agenda .sc-list-container {
    overflow: hidden !important;
  }

  /* Hide scrollbar styles */
  #calendar-agenda *::-webkit-scrollbar {
    display: none;
  }

  #calendar-agenda * {
    scrollbar-width: none;
  }

  /* Force day view to fill height */
  #calendar-agenda .sc-day-view,
  #calendar-agenda .sc-list-view,
  #calendar-agenda .sc-view-container,
  #calendar-agenda .sc-container {
    height: 100% !important;
    max-height: none !important;
    min-height: 100vh !important;
  }

  /* Allow overflow on time columns so overlapping events can render side-by-side */
  #calendar-agenda .sc-time-col {
    overflow: visible !important;
    position: relative !important;
  }
</style>

<div class="view view--full">
  <div class="layout layout--col layout--top">
    <div id="calendar-agenda"></div>
  </div>
  {% if view_mode == 'list' %}
  <div class="title_bar">
    <span class="title">{{ calendar_title }}</span>
    <span class="instance">{{ today_label }}</span>
  </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var VIEW_MODE = '{{ view_mode }}';
    var userLocale = {{ trmnl.user.locale | default: "en-US" | json }};
    var currentUtcEpoch = {{ agenda_now_utc_epoch }};
    
    var eventsData = [
      {% for event in events %}
      {% assign start_local_epoch = event.start | date: "%s" | plus: effective_utc_offset %}
      {% assign end_local_epoch = event.end | date: "%s" | plus: effective_utc_offset %}
      buildAgendaEvent({
        id: '{{ event.uid }}',
        title: '{{ event.summary }}',
        startEpoch: {{ event.start | date: "%s" | plus: 0 }},
        endEpoch: {{ event.end | date: "%s" | plus: 0 }},
        startDateKey: '{{ event.start_date }}',
        endDateKey: '{{ event.end_date }}',
        startHour: {{ start_local_epoch | date: "%H" | plus: 0 }},
        startMinute: {{ start_local_epoch | date: "%M" | plus: 0 }},
        endHour: {{ end_local_epoch | date: "%H" | plus: 0 }},
        endMinute: {{ end_local_epoch | date: "%M" | plus: 0 }},
        startLabel12: '{{ start_local_epoch | date: "%-I:%M %p" }}',
        startLabel24: '{{ start_local_epoch | date: "%H:%M" }}',
        endLabel12: '{{ end_local_epoch | date: "%-I:%M %p" }}',
        endLabel24: '{{ end_local_epoch | date: "%H:%M" }}',
        allDay: {{ event.all_day }},
        source: '{{ event.source | default: "default" }}'
      }){% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
    applyAgendaSourceColors(eventsData);

    var fetchEventsFunc = buildAgendaFetchEvents(
      eventsData,
      currentUtcEpoch,
      '{{ agenda_today_local_date }}'
    );

    initializeAgendaCalendar({
      selector: '#calendar-agenda',
      viewMode: VIEW_MODE,
      todayDateKey: '{{ agenda_today_local_date }}',
      currentUtcEpoch: currentUtcEpoch,
      locale: userLocale,
      use24Hour: false,
      listDaysForward: 7,
      showGridLines: true,
      fetchEvents: fetchEventsFunc,
      eventsData: eventsData
    });
  });
</script>

{% endif %}
