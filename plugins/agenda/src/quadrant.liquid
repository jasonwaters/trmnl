{% assign view_mode = trmnl.plugin_settings.custom_fields_values.view_mode | default: "basic_list" %}

{% if view_mode == 'basic_list' %}
<!-- ============================================================================ -->
<!-- Basic List Mode - TRMNL Framework Components (Quadrant Micro) -->
<!-- ============================================================================ -->

<style media="screen">
  .agenda-list-quadrant {
    padding: 4px 6px;
    justify-content: flex-start !important;
    align-items: stretch !important;
  }

  .agenda-item-quadrant {
    margin-bottom: 3px;
  }

  .agenda-item-quadrant:last-child {
    margin-bottom: 0;
  }

  .agenda-item-quadrant .title--small {
    font-size: 9px !important;
  }

  .agenda-item-quadrant .label--small {
    font-size: 7px !important;
  }

  .agenda-time-quadrant {
    white-space: nowrap;
  }

  .agenda-item-quadrant .description {
    display: none;
  }

  .agenda-item-quadrant .meta {
    display: none;
  }
</style>

{% assign today_label = agenda_today_label %}
{% assign calendar_title = calendar_name | default: "Agenda" %}

<div class="view view--quadrant">
<div class="layout layout--col layout--top agenda-list-quadrant">
  {% assign window_start_date = agenda_today_local_date %}
  {% assign window_start_epoch = agenda_now_local_epoch %}
  {% assign window_end_epoch = window_start_epoch | plus: 86400 %}
  {% assign window_end_date = window_end_epoch | date: "%Y-%m-%d" %}
  {% assign last_rendered_date = "" %}
  {% assign displayed_count = 0 %}
  {% assign sources = events | map: "source" | uniq %}
  
  {% for event in events %}
        {% if event.start_date > window_end_date %}
          {% break %}
        {% endif %}
        {% assign event_end_epoch = event.end | date: "%s" | plus: 0 %}
        {% if event_end_epoch <= agenda_now_utc_epoch %}
          {% continue %}
        {% endif %}
        {% assign overlaps_window = false %}
        {% if event.all_day %}
          {% if event.end_date > window_start_date and event.start_date <= window_end_date %}
            {% assign overlaps_window = true %}
          {% endif %}
        {% else %}
          {% if event.end_date >= window_start_date and event.start_date <= window_end_date %}
            {% assign overlaps_window = true %}
          {% endif %}
        {% endif %}
        {% if overlaps_window %}
          {% assign display_date = event.start_date %}
          {% if event.start_date < window_start_date %}
            {% assign display_date = window_start_date %}
          {% endif %}
          {% assign displayed_count = displayed_count | plus: 1 %}
          {% if displayed_count > 3 %}
            {% break %}
          {% endif %}
          {% if display_date != last_rendered_date %}
            {% assign last_rendered_date = display_date %}
            <span class="label label--small label--underline">{{ display_date | date: "%a, %b %-d" }}</span>
          {% endif %}
        {% else %}
          {% continue %}
        {% endif %}
        {% assign source_index = 0 %}
        {% for source in sources %}
          {% if source == event.source %}
            {% assign source_index = forloop.index %}
            {% break %}
          {% endif %}
        {% endfor %}
        
        {% assign emphasis_level = source_index | modulo: 3 | plus: 1 %}
        
        <div class="item agenda-item-quadrant item--emphasis-{{ emphasis_level }}">
          <div class="meta"></div>
          <div class="content">
            <span class="title title--small">{{ event.summary | default: "Untitled event" }}</span>
            <div class="flex gap--small">
              {% if event.all_day %}
                <span class="label label--small label--underline">All Day</span>
              {% else %}
                {% assign start_local_epoch = event.start | date: "%s" | plus: effective_utc_offset %}
                {% assign display_start = start_local_epoch | date: "%-I:%M %p" %}
                <span
                  class="label label--small label--underline agenda-time-quadrant"
                >
                  {{ display_start }}
                </span>
              {% endif %}
            </div>
          </div>
        </div>
  {% endfor %}
  
  {% if displayed_count == 0 %}
    <div class="item agenda-item-quadrant">
      <div class="meta"></div>
      <div class="content">
        <span class="title title--small">No events today</span>
      </div>
    </div>
  {% endif %}
</div>
<div class="title_bar">
  <span class="title">{{ calendar_title }}</span>
  <span class="instance">{{ today_label }}</span>
</div>
</div>

{% else %}
<!-- ============================================================================ -->
<!-- List Mode Only - SimpleCalendarJS (Quadrant Micro) -->
<!-- ============================================================================ -->

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;700&display=swap">
<link rel="stylesheet" href="https://unpkg.com/simple-calendar-js/dist/simple-calendar-js.min.css">
<script src="https://unpkg.com/simple-calendar-js/dist/simple-calendar-js.min.js"></script>

<style media="screen">
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    width: 100%;
    overflow: hidden;
  }

  #calendar-agenda-quad {
    height: 100vh;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
  }

  #calendar-agenda-quad * {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 9px;
    line-height: 1.1;
  }

  /* List view - micro */
  #calendar-agenda-quad .sc-list-event {
    border-left: 2px solid black;
    padding: 3px;
    margin-bottom: 2px;
    background-color: white;
  }

  #calendar-agenda-quad .sc-list-event-title {
    font-weight: 700;
    margin-bottom: 1px;
    font-size: 9px;
  }

  #calendar-agenda-quad .sc-list-event-time {
    font-size: 8px;
    opacity: 0.8;
  }

  #calendar-agenda-quad .sc-list-date-header {
    font-weight: 700;
    font-size: 10px;
    text-transform: uppercase;
    margin: 4px 0 3px 0;
    padding-bottom: 2px;
    border-bottom: 1px solid black;
  }

  /* Hide current time indicator */
  #calendar-agenda-quad .uc-now-indicator,
  #calendar-agenda-quad .uc-now-dot,
  #calendar-agenda-quad .uc-now-line {
    display: none !important;
  }

  /* Remove scrollbars */
  #calendar-agenda-quad .sc-scroller,
  #calendar-agenda-quad .sc-body,
  #calendar-agenda-quad .sc-list-view,
  #calendar-agenda-quad .sc-list-container {
    overflow: hidden !important;
  }

  /* Hide scrollbar styles */
  #calendar-agenda-quad *::-webkit-scrollbar {
    display: none;
  }

  #calendar-agenda-quad * {
    scrollbar-width: none;
  }

  /* Force list view to fill height */
  #calendar-agenda-quad .sc-list-view,
  #calendar-agenda-quad .sc-view-container,
  #calendar-agenda-quad .sc-container {
    height: 100% !important;
    max-height: none !important;
    min-height: 100vh !important;
  }

  /* Allow overflow on time columns so overlapping events can render side-by-side */
  #calendar-agenda-quad .sc-time-col {
    overflow: visible !important;
    position: relative !important;
  }
</style>

<div id="calendar-agenda-quad"></div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var VIEW_MODE = 'list';
    var userLocale = {{ trmnl.user.locale | default: "en-US" | json }};
    var currentUtcEpoch = {{ agenda_now_utc_epoch }};

    var eventsData = [
      {% for event in events %}
      {
        id: '{{ event.uid }}',
        title: '{{ event.summary }}',
        startEpoch: {{ event.start | date: "%s" | plus: 0 }},
        endEpoch: {{ event.end | date: "%s" | plus: 0 }},
        start: new Date('{{ event.start }}'),
        end: new Date('{{ event.end }}'),
        startDateKey: '{{ event.start_date }}',
        endDateKey: '{{ event.end_date }}',
        allDay: {{ event.all_day }},
        source: '{{ event.source | default: "default" }}',
        color: null,
        textColor: null
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];

    var sources = [...new Set(eventsData.map(e => e.source))];
    var sourceColors = {};
    var sourceTextColors = {};
    
    var colorPatterns = [
      ['#000000', '#ffffff'],
      ['#cccccc', '#000000'],
      ['#333333', '#ffffff'],
      ['#e6e6e6', '#000000']
    ];
    
    sources.forEach(function(source, i) {
      var pattern = colorPatterns[i % colorPatterns.length];
      sourceColors[source] = pattern[0];
      sourceTextColors[source] = pattern[1];
    });

    eventsData.forEach(function(event) {
      event.color = sourceColors[event.source] || '#000000';
      event.textColor = sourceTextColors[event.source] || '#ffffff';
    });

    var fetchEventsFunc = function(start, end) {
      var visibleStartEpoch = getVisibleStartEpoch(eventsData, currentUtcEpoch, '{{ agenda_today_local_date }}');
      return eventsData.filter(function(e) {
        return isEventVisibleForAgenda(e, visibleStartEpoch, currentUtcEpoch);
      });
    };

    var calendar = new SimpleCalendarJs('#calendar-agenda-quad', {
      defaultView: 'list',
      defaultDate: new Date('{{ agenda_today_local_date }}T00:00:00'),
      weekStartsOn: 0,
      use24Hour: false,
      showToolbar: false,
      showTodayButton: false,
      showNavigation: false,
      showViewSwitcher: false,
      showYearPicker: false,
      showTooltips: false,
      showGridLines: false,
      showBorder: false,
      enableDragDrop: false,
      enableResize: false,
      listDaysForward: 1,
      fetchEvents: fetchEventsFunc
    });

    applyTimezoneSafeListView(calendar, {
      todayDateKey: '{{ agenda_today_local_date }}',
      currentUtcEpoch: currentUtcEpoch,
      locale: userLocale,
      use24Hour: false
    });
    if (typeof calendar._renderBody === 'function') {
      calendar._renderBody();
    }

    calendar._scrollToBusinessHours = function(vc) {
      requestAnimationFrame(function() {
        var body = vc.querySelector('.uc-time-body');
        if (!body) return;
        var hourH = parseFloat(
          getComputedStyle(calendar._root).getPropertyValue('--cal-hour-height')
        ) || 60;
        
        var startHour = calculateDayViewStartHour(eventsData, currentUtcEpoch, '{{ agenda_today_local_date }}');
        body.scrollTop = startHour * hourH;
      });
    };
  });
</script>

{% endif %}
