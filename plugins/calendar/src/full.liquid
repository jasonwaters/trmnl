{% assign raw_utc_offset = trmnl.user.utc_offset | plus: 0 %}
{% assign utc_offset = raw_utc_offset %}
{% if raw_utc_offset != 0 %}
  {% assign abs_utc_offset = raw_utc_offset | abs %}
  {% if abs_utc_offset <= 24 %}
    {% assign utc_offset = raw_utc_offset | times: 3600 %}
  {% elsif abs_utc_offset <= 840 %}
    {% assign utc_offset = raw_utc_offset | times: 60 %}
  {% endif %}
{% endif %}
{% assign effective_utc_offset = utc_offset %}
{% assign calendar_now_utc_epoch = trmnl.system.timestamp_utc | plus: 0 %}
{% assign calendar_today_local_epoch = calendar_now_utc_epoch | plus: effective_utc_offset %}
{% assign calendar_today_local_date = calendar_today_local_epoch | date: "%Y-%m-%d" %}
{% assign show_calendar_title_setting = trmnl.plugin_settings.custom_fields_values.show_calendar_title | default: "false" %}
{% assign show_calendar_title = false %}
{% if show_calendar_title_setting == "true" or show_calendar_title_setting == true %}
  {% assign show_calendar_title = true %}
{% endif %}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;500;700&display=swap">

<style media="screen">
  /* Reset framework defaults */
  * {
    box-sizing: border-box;
  }
  
  /* Override any framework padding on the view wrapper */
  .view--full {
    padding: 0 !important;
    margin: 0 !important;
    width: 100% !important;
    height: 100% !important;
    max-width: 100% !important;
    max-height: 100% !important;
  }

  /* Use TRMNL framework dimensions - .layout already gets width/height from framework */
  .layout {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
    margin: 0;
    width: 100%;
    height: 100%;
  }

  #calendar-full-month-fc {
    -webkit-font-smoothing: none !important;
    flex: 1;
    width: 100%;
    height: 100%;
    min-width: 100%;
    min-height: 0;
    max-width: 100%;
    padding: 0;
    margin: 0;
    overflow: hidden;
  }

  /* Force FullCalendar root to fill container */
  #calendar-full-month-fc .fc {
    height: 100% !important;
    width: 100% !important;
    max-width: 100% !important;
    --fc-today-bg-color: transparent;
  }

  .fc-view-harness {
    height: 100% !important;
  }

  /* Common FullCalendar styles based on TRMNL official implementation */
  .fc-v-event .fc-event-title {
    font-size: 13px;
    line-height: 14px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 500;
  }

  .fc-daygrid-dot-event .fc-event-title {
    font-weight: 400;
  }

  .fc-daygrid-event-dot {
    display: none;
  }

  .fc-col-header-cell {
    font-family: 'Roboto Mono', monospace;
    font-size: 14px;
    line-height: 18px;
    font-weight: 700;
    overflow: visible !important;
  }

  .fc .fc-col-header-cell-cushion {
    display: inline-block !important;
    padding: 8px 4px !important;
  }

  .fc-col-header {
    height: auto !important;
    overflow: visible !important;
  }

  .fc-scrollgrid-section-header {
    height: auto !important;
    overflow: visible !important;
  }

  .fc-scrollgrid-section-header > * {
    overflow: visible !important;
  }

  .fc-scrollgrid-section-header td {
    overflow: visible !important;
  }

  .fc-v-event {
    background-color: var(--fc-event-bg-color);
    border: 1px solid var(--fc-event-border-color);
    display: block;
  }

  .fc-daygrid-day::after {
    content: " ";
    position: absolute;
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    bottom: 0;
    left: -1px;
    width: 1px;
    height: 100%;
    background: repeat url(https://usetrmnl.com/images/borders/5.png);
  }

  .fc-theme-standard td, .fc-theme-standard th {
    border: 1px dashed;
  }

  /* Responsive day cells - let them fill available space */
  .fc-day {
    width: auto;
  }

  .fc .fc-day-other .fc-daygrid-day-top {
    opacity: 1.0;
  }

  .fc .fc-col-header-cell {
    border: none !important;
  }

  .fc .fc-daygrid-day.fc-day-today {
    background-color: transparent;
    border: 2px solid black;
    border-left: 3px solid black;
    border-right: 3px solid black;
  }

  .fc table,
  .fc-daygrid-event {
    font-size: 13px;
    line-height: 14px;
    font-family: 'Roboto Mono', monospace;
  }

  /* Remove hard-coded widths - let tables be responsive */
  table.fc-col-header {
    width: 100% !important;
    max-width: 100% !important;
  }

  table.fc-col-header col {
    width: auto !important;
  }
  
  /* Ensure all tables and scrollers respect container width */
  .fc table {
    width: 100% !important;
    max-width: 100% !important;
    table-layout: fixed !important;
  }
  
  .fc-scroller,
  .fc-scroller-liquid,
  .fc-scroller-liquid-absolute {
    overflow: hidden !important;
    max-width: 100% !important;
  }

  .fc-day-today {
    background-color: transparent !important;
  }

  .fc-daygrid-event {
    white-space: normal !important;
  }

  .fc .fc-daygrid-body-unbalanced .fc-daygrid-day-events {
    min-height: 1em;
  }

  .fc-event {
    display: block;
  }

  .fc-event-time {
    text-decoration: underline;
  }
</style>

<div class="layout">
  <div id="calendar-full-month-fc"></div>
</div>
{% if show_calendar_title %}
<div class="title_bar">
  <span class="title">{{ calendar_name | default: "Calendar" }}</span>
</div>
{% endif %}

<script src='https://usetrmnl.com/fullcalendar/index.global.min.js'></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var userLocale = {{ trmnl.user.locale | default: "en-US" | json }};
    var todayDateKey = '{{ calendar_today_local_date }}';

    function addOneDayToDateKey(dateKey) {
      if (!dateKey) return dateKey;
      var parts = String(dateKey).split('-');
      if (parts.length !== 3) return dateKey;
      var dateObj = new Date(Date.UTC(
        parseInt(parts[0], 10),
        parseInt(parts[1], 10) - 1,
        parseInt(parts[2], 10)
      ));
      dateObj.setUTCDate(dateObj.getUTCDate() + 1);
      return dateObj.toISOString().slice(0, 10);
    }

    // Configuration: View mode is set via custom field in settings.yml
    // Options: 'oneWeek', 'twoWeek', or 'month'
    var VIEW_MODE = '{{ trmnl.plugin_settings.custom_fields_values.view_mode | default: "twoWeek" }}';

    var eventsData = [
      {% for event in events %}
      {
        id: '{{ event.uid }}',
        title: '{{ event.summary }}',
        start: '{{ event.start }}',
        end: '{{ event.end }}',
        startDate: '{{ event.start_date }}',
        endDate: '{{ event.end_date }}',
        startLocal: '{% assign event_start_local_epoch = event.start | date: "%s" | plus: effective_utc_offset %}{{ event_start_local_epoch | date: "%Y-%m-%dT%H:%M:%S" }}',
        endLocal: '{% assign event_end_local_epoch = event.end | date: "%s" | plus: effective_utc_offset %}{{ event_end_local_epoch | date: "%Y-%m-%dT%H:%M:%S" }}',
        extendedProps: {
          source: '{{ event.source | default: "default" }}'
        }
      }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];

    console.log('Events loaded:', eventsData.length);
    if (eventsData.length === 0) {
      console.error('No events found! Check that static_data is being parsed correctly.');
      document.getElementById('calendar-full-month-fc').innerHTML = '<div style="padding: 20px; text-align: center;">No events data available. Check console for details.</div>';
      return;
    }
    console.log('First event:', eventsData[0]);

    var sources = [...new Set(eventsData.map(e => e.extendedProps.source))];
    var colorPatterns = [
      ['#000000', '#ffffff'],
      ['#cccccc', '#000000'],
      ['#333333', '#ffffff'],
      ['#e6e6e6', '#000000']
    ];

    var calendarEvents = eventsData.map(function(event) {
      var sourceIndex = sources.indexOf(event.extendedProps.source);
      var pattern = colorPatterns[sourceIndex % colorPatterns.length];

      var calEvent = {
        id: event.id,
        title: event.title,
        backgroundColor: pattern[0],
        borderColor: pattern[0],
        textColor: pattern[1]
      };

      // Multi-day events (including reservations) should be all-day
      if (event.startDate !== event.endDate) {
        calEvent.allDay = true;
        calEvent.start = event.startDate;
        // FullCalendar all-day events need exclusive end date (day after last day)
        calEvent.end = addOneDayToDateKey(event.endDate);
      } else {
        // Single-day timed events
        calEvent.allDay = false;
        // Use server-derived local wall-clock values (no timezone suffix) to avoid runtime timezone drift.
        calEvent.start = event.startLocal;
        calEvent.end = event.endLocal;
      }

      return calEvent;
    });

    // Determine view configuration based on VIEW_MODE
    var initialView, viewConfig;

    if (VIEW_MODE === 'oneWeek') {
      initialView = 'dayGridWeek';
      viewConfig = {
        dayGridWeek: {
          type: 'dayGrid',
          duration: { weeks: 1 }
        }
      };
    } else if (VIEW_MODE === 'twoWeek') {
      initialView = 'dayGridTwoWeek';
      viewConfig = {
        dayGridTwoWeek: {
          type: 'dayGrid',
          duration: { weeks: 2 },
          dateIncrement: { weeks: 1 }
        }
      };
    } else {
      // Full month view
      initialView = 'dayGridMonth';
      viewConfig = {};
    }

    var calendarEl = document.getElementById('calendar-full-month-fc');

    // Calculate actual available dimensions
    var containerWidth = calendarEl.offsetWidth || calendarEl.parentElement.offsetWidth || 800;
    var containerHeight = calendarEl.offsetHeight || calendarEl.parentElement.offsetHeight || 480;
    
    console.log('Container dimensions:', containerWidth, 'x', containerHeight);

    var calendar = new FullCalendar.Calendar(calendarEl, {
      initialView: initialView,
      initialDate: todayDateKey,
      // Events are already shifted to local wall-clock values in Liquid.
      timeZone: 'local',
      locale: userLocale,
      firstDay: 0,
      headerToolbar: false,
      height: containerHeight,
      contentHeight: containerHeight,
      views: viewConfig,
      fixedWeekCount: false,
      showNonCurrentDates: true,
      displayEventTime: true,
      eventTimeFormat: {
        hour: 'numeric',
        minute: '2-digit',
        meridiem: 'short'
      },
      events: calendarEvents
    });

    calendar.render();
  });
</script>
