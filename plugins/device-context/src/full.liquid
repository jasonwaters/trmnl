{% assign device_context_suffix = "device-context" | append_random %}
{% assign device_context_instance_key = device_context_suffix %}
{% assign liquid_timezone_id = "liquid-timezone-" | append: device_context_suffix %}
{% assign liquid_utc_offset_id = "liquid-utc-offset-" | append: device_context_suffix %}
{% assign js_intl_timezone_id = "js-intl-timezone-" | append: device_context_suffix %}
{% assign js_timezone_offset_id = "js-timezone-offset-" | append: device_context_suffix %}
{% assign timezone_consistency_id = "timezone-consistency-status-" | append: device_context_suffix %}

<div class="layout layout--col layout--top p--2">
  <div class="item">
    <div class="meta"></div>
    <div>
      <span class="label label--small label--underline">friendly_id</span>
      <span class="title">{{ trmnl.device.friendly_id }}</span>
    </div>
  </div>

  <div class="item">
    <div class="meta"></div>
    <div>
      <span class="label label--small label--underline">dimensions</span>
      <span class="title">{{ trmnl.device.width }} x {{ trmnl.device.height }}</span>
    </div>
  </div>

  <div class="item">
    <div class="meta"></div>
    <div>
      <span class="label label--small label--underline">battery / wifi</span>
      <span class="title">{{ trmnl.device.percent_charged }}% / {{ trmnl.device.wifi_strength }}</span>
    </div>
  </div>

  <div class="item">
    <div class="meta"></div>
    <div>
      <span class="label label--small label--underline">user.time_zone_iana (Liquid)</span>
      <span class="title" id="{{ liquid_timezone_id }}">{{ trmnl.user.time_zone_iana }}</span>
    </div>
  </div>

  <div class="item">
    <div class="meta"></div>
    <div>
      <span class="label label--small label--underline">user.utc_offset (Liquid seconds)</span>
      <span class="title" id="{{ liquid_utc_offset_id }}">{{ trmnl.user.utc_offset }}</span>
    </div>
  </div>

  <div class="item">
    <div class="meta"></div>
    <div>
      <span class="label label--small label--underline">JS Intl timezone</span>
      <span class="title" id="{{ js_intl_timezone_id }}">loading...</span>
    </div>
  </div>

  <div class="item">
    <div class="meta"></div>
    <div>
      <span class="label label--small label--underline">JS timezone offset (minutes)</span>
      <span class="title" id="{{ js_timezone_offset_id }}">loading...</span>
    </div>
  </div>

  <div class="item">
    <div class="meta"></div>
    <div>
      <span class="label label--small label--underline">timezone consistency</span>
      <span class="title" id="{{ timezone_consistency_id }}">checking...</span>
    </div>
  </div>

  <div class="item">
    <div class="meta"></div>
    <div>
      <span class="label label--small label--underline">device json</span>
      <span class="label label--small">{{ trmnl.device | json }}</span>
    </div>
  </div>
</div>

  <div class="title_bar">
    <span class="title">Device Debug</span>
    <span class="instance">{{ trmnl.device.friendly_id }}</span>
  </div>

  <script>
    (function() {
      var tzElement = document.getElementById({{ js_intl_timezone_id | json }});
      var offsetElement = document.getElementById({{ js_timezone_offset_id | json }});
      var liquidTzElement = document.getElementById({{ liquid_timezone_id | json }});
      var liquidOffsetElement = document.getElementById({{ liquid_utc_offset_id | json }});
      var statusElement = document.getElementById({{ timezone_consistency_id | json }});
      if (!tzElement || !offsetElement || !liquidTzElement || !liquidOffsetElement || !statusElement) return;

      var runtimeTimezone = 'unknown';
      try {
        runtimeTimezone = Intl.DateTimeFormat().resolvedOptions().timeZone || 'unknown';
      } catch (error) {
        runtimeTimezone = 'error';
      }

      var runtimeOffsetMinutes = new Date().getTimezoneOffset();

      tzElement.textContent = runtimeTimezone;
      offsetElement.textContent = String(runtimeOffsetMinutes);

      var liquidTimezone = (liquidTzElement.textContent || '').trim();
      var liquidOffsetSeconds = parseInt((liquidOffsetElement.textContent || '').trim(), 10);
      var runtimeOffsetSeconds = -runtimeOffsetMinutes * 60;

      var timezoneMatch = liquidTimezone && runtimeTimezone && liquidTimezone === runtimeTimezone;
      var offsetMatch = !Number.isNaN(liquidOffsetSeconds) && liquidOffsetSeconds === runtimeOffsetSeconds;

      if (timezoneMatch && offsetMatch) {
        statusElement.textContent = 'MATCH';
      } else {
        statusElement.textContent = 'MISMATCH (Liquid: ' + liquidTimezone + ' / ' + liquidOffsetSeconds + 's, JS: ' + runtimeTimezone + ' / ' + runtimeOffsetSeconds + 's)';
      }
    })();
  </script>