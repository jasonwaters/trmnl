<div class="layout layout--col layout--center gp-stage w--full h--full p--2">
  <div class="gp-coupon w--full h--full">
    <div class="gp-coupon-dark flex flex--col flex--center-y flex--center-x text--center gap--medium">
      <span class="gp-eyebrow">Book Your Next Stay</span>

      <span class="gp-offer">{{ gp_offer }}</span>

      <span class="gp-subline">at Rad Retreat</span>

      <div class="flex flex--col flex--center-x gap--small">
        <span class="gp-codelabel">Use Promo Code</span>
        <span class="gp-code">{{ gp_promo_code }}</span>
      </div>
    </div>

    <div class="gp-coupon-light flex flex--col flex--center-y flex--center-x gap--small">
      <div id="{{ gp_qr_id }}" class="gp-qr" data-url="{{ gp_booking_url | escape }}" data-size="176"></div>
      <span class="gp-qrcap">Scan to Book</span>
    </div>
  </div>
</div>

{% if gp_show_title_bar %}
<div class="title_bar gp-titlebar">
  <span class="title">{{ gp_site_name }}</span>
</div>
{% endif %}
