<div class="layout layout--col layout--center gp-stage gp-narrow w--full h--full p--4">
  <div class="gp-frame flex flex--col flex--center-y flex--center-x text--center gap--small w--full h--full">
    <span class="gp-eyebrow">Book Your Next Stay</span>

    <span class="gp-offer">{{ gp_offer }}</span>

    <hr class="gp-rule" />

    <span class="gp-codelabel">Use Promo Code</span>
    <span class="gp-code">{{ gp_promo_code }}</span>

    <div class="flex flex--col flex--center-x gap--small">
      <div id="{{ gp_qr_id }}" class="gp-qr" data-url="{{ gp_booking_url | escape }}" data-size="112"></div>
      <span class="gp-qrcap">Scan to Book</span>
    </div>
  </div>
</div>

{% if gp_show_title_bar %}
<div class="title_bar gp-titlebar">
  <span class="title">{{ gp_site_name }}</span>
</div>
{% endif %}
