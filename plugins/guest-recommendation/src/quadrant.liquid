<div class="layout layout--col layout--center gr-stage gr-compact gr-quad w--full h--full p--1">
  <div class="gr-frame flex flex--row flex--center-y gap--medium w--full h--full">
    <div class="gr-icon">
      <div class="gr-icon-art">{{ gr_icon_markup }}</div>
    </div>

    <div class="flex flex--col gap--xsmall gr-textcol">
      {% if gr_tag != "" %}<span class="gr-eyebrow">{{ gr_tag }}</span>{% endif %}
      <span class="gr-title">{{ gr_title }}</span>
      <span class="gr-body">{{ gr_body }}</span>
    </div>
  </div>
</div>

{% if gr_show_title_bar %}
<div class="title_bar gr-titlebar">
  <span class="title">{{ gr_site_name }}</span>
</div>
{% endif %}
