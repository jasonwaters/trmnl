{% comment %}
  ---------- Brand styling (radretreat.com) ----------
  Matches guest-welcome / guest-promotion: Bricolage Grotesque display + Nunito
  Sans body, pure black/white for crisp e-ink. Layout structure stays in the
  framework classes; this only adds brand type, the icon medallion, and the
  responsive tiers.
{% endcomment %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Nunito+Sans:ital,opsz,wght@0,6..12,400;0,6..12,600;0,6..12,700&display=swap" rel="stylesheet">

<style>
  .gr-stage { font-family: "Nunito Sans", sans-serif; color: #000; }

  .gr-frame { border: 2px solid #000; padding: 30px 36px; }

  /* The framework's flex--col centers children; the row layouts want the text
     block left-aligned so the title and body share a left edge. */
  .gr-textcol { align-items: flex-start; text-align: left; }

  /* Icon medallion: a ruled circle holding the line art. */
  .gr-icon {
    color: #000;
    border: 2px solid #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 200px;
    height: 200px;
  }
  .gr-icon-art {
    width: 116px;
    height: 116px;
    line-height: 0;
  }

  .gr-eyebrow {
    font-family: "Nunito Sans", sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    text-indent: 0.3em;
    font-size: 16px;
    line-height: 1.2;
    color: #000;
  }

  .gr-title {
    display: block;
    font-family: "Bricolage Grotesque", "Nunito Sans", sans-serif;
    font-weight: 800;
    letter-spacing: 0.005em;
    line-height: 0.98;
    font-size: 52px;
    /* Match the 1-bit hardening used on the other plugins: lock optical sizing
       and fatten glyph edges a hair so they threshold to solid black. */
    font-optical-sizing: none;
    -webkit-text-stroke: 0.4px #000;
    color: #000;
  }

  .gr-rule { width: 84px; height: 0; border: 0; border-top: 3px solid #000; margin: 2px 0; }

  .gr-body {
    font-family: "Nunito Sans", sans-serif;
    font-weight: 600;
    font-size: 21px;
    line-height: 1.32;
    color: #000;
  }

  .gr-brand {
    font-family: "Nunito Sans", sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    text-indent: 0.24em;
    font-size: 12px;
    color: #000;
  }

  .gr-titlebar .title {
    font-family: "Nunito Sans", sans-serif !important;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: lowercase;
  }

  /* Narrow tier (half_vertical): icon on top, text stacked below. */
  .gr-narrow .gr-frame { padding: 22px 24px; }
  .gr-narrow .gr-icon { width: 132px; height: 132px; }
  .gr-narrow .gr-icon-art { width: 78px; height: 78px; }
  .gr-narrow .gr-eyebrow { font-size: 13px; letter-spacing: 0.22em; text-indent: 0.22em; }
  .gr-narrow .gr-title { font-size: 38px; }
  .gr-narrow .gr-body { font-size: 18px; line-height: 1.3; }
  .gr-narrow .gr-rule { margin-left: auto; margin-right: auto; }

  /* Compact tier (half_horizontal, quadrant). */
  .gr-compact .gr-frame { padding: 16px 20px; }
  .gr-compact .gr-icon { width: 104px; height: 104px; border-width: 2px; }
  .gr-compact .gr-icon-art { width: 60px; height: 60px; }
  .gr-compact .gr-eyebrow { font-size: 11px; letter-spacing: 0.2em; text-indent: 0.2em; }
  .gr-compact .gr-title { font-size: 30px; line-height: 0.98; -webkit-text-stroke: 0.3px #000; }
  .gr-compact .gr-rule { width: 56px; border-top-width: 2px; }
  .gr-compact .gr-body { font-size: 15px; line-height: 1.28; }

  /* Quadrant is tightest: trim the icon and body further. */
  .gr-quad .gr-icon { width: 76px; height: 76px; }
  .gr-quad .gr-icon-art { width: 46px; height: 46px; }
  .gr-quad .gr-title { font-size: 23px; }
  .gr-quad .gr-body { font-size: 13px; line-height: 1.25; }
</style>
