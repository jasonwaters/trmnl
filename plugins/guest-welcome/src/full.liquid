<div class="layout layout--col layout--center text--center w--full h--full p--6">
  {% if gw_has_guest %}
    <div class="flex flex--col flex--center-y flex--center-x gap--small w--full">
      <span class="label">{{ gw_welcome_line }}</span>

      <span class="value value--xxlarge" data-value-fit="true" data-value-fit-max-height="200">
        {{ gw_greeting_name }}
      </span>

      <div class="flex flex--col flex--center-y flex--center-x gap--small mt--3">
        <span class="title title--medium">{{ gw_stay_range }}</span>
        {% if gw_nights_label != "" %}
          <span class="label label--small text--gray-3">{{ gw_nights_label }}</span>
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="flex flex--col flex--center-y flex--center-x gap--small w--full">
      <span class="value value--xlarge">{{ gw_welcome_line }}</span>
      <span class="label label--small text--gray-3 mt--2">We're delighted to have you.</span>
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <span class="title">{{ gw_site_name }}</span>
</div>
