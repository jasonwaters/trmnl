<div class="layout layout--col layout--center gw-stage gw-narrow w--full h--full p--4">
  {% if gw_has_guest %}
    <div class="gw-frame flex flex--col flex--center-y flex--center-x text--center gap--medium w--full h--full">
      <span class="gw-eyebrow">{{ gw_welcome_line }}</span>

      <span class="gw-name">{{ gw_greeting_name }}</span>

      <hr class="gw-rule" />

      <div class="flex flex--col flex--center-y flex--center-x gap--small">
        <span class="gw-dates">{{ gw_stay_range }}</span>
        {% if gw_nights_label != "" %}
          <span class="gw-nights">{{ gw_nights_label }}</span>
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="gw-frame flex flex--col flex--center-y flex--center-x text--center gap--small w--full h--full">
      <span class="gw-eyebrow">{{ gw_welcome_line }}</span>
      <span class="gw-name">Welcome</span>
    </div>
  {% endif %}
</div>

{% if gw_show_title_bar %}
<div class="title_bar gw-titlebar">
  <span class="title">{{ gw_site_name }}</span>
</div>
{% endif %}
