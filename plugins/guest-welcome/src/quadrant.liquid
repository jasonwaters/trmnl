<div class="layout layout--col layout--center gw-stage gw-compact w--full h--full p--1">
  {% if gw_has_guest %}
    <div class="gw-frame flex flex--col flex--center-y flex--center-x text--center gap--small w--full h--full">
      <span class="gw-eyebrow">Welcome</span>

      <span class="gw-name">{{ gw_greeting_name }}</span>

      <span class="gw-dates">{{ gw_stay_range }}</span>
    </div>
  {% else %}
    <div class="gw-frame flex flex--col flex--center-y flex--center-x text--center w--full h--full">
      <span class="gw-eyebrow">Welcome</span>
    </div>
  {% endif %}
</div>

{% if gw_show_title_bar %}
<div class="title_bar gw-titlebar">
  <span class="title">{{ gw_site_name }}</span>
</div>
{% endif %}
