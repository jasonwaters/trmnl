<div class="layout layout--col h--full">
  <div class="grid grid--cols-1">
    <div class="item">
      <div class="content">
        <span class="value value--tnums" id="current-weight">-</span>
        <span class="label">CURRENT</span>
      </div>
    </div>
  </div>

  <div id="health-chart" class="w--full h--full"></div>
</div>

<div class="title_bar">
  <span class="title" id="chart-title">{{ profileName | capitalize }}'s Trend</span>
  <span class="instance">Last {{ measurements.size }} Measurements</span>
</div>

<script type="text/javascript">
  initializeHealthChart({
    chartElementId: 'health-chart',
    currentValueId: 'current-weight',
    chartTitleId: 'chart-title',
    axisFontSize: '13px',
    lineWidth: 3
  });
</script>
