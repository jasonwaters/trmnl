{% assign immich_settings = trmnl.plugin_settings.custom_fields_values %}
{% assign immich_asset = data[0] %}
{% assign immich_original_path_parts = immich_asset.originalPath | default: '' | split: '/' %}
{% assign immich_file_name = immich_asset.originalFileName | default: immich_original_path_parts.last | default: immich_asset.deviceAssetId | default: 'Immich image' %}
{% assign immich_taken_at = immich_asset.localDateTime | default: immich_asset.fileCreatedAt | default: '' %}
{% assign immich_taken_date_label = '' %}
{% if immich_taken_at != '' %}
  {% assign immich_taken_date_key = immich_taken_at | split: 'T' | first %}
  {% assign immich_taken_date_label = immich_taken_date_key | date: '%b %-d, %Y' %}
{% endif %}
{% assign immich_show_title_bar_value = immich_settings.show_title_bar | default: 'yes' | append: '' | downcase %}
{% assign immich_show_title_bar = true %}
{% if immich_show_title_bar_value == 'false' or immich_show_title_bar_value == '0' or immich_show_title_bar_value == 'no' or immich_show_title_bar_value == 'off' %}
  {% assign immich_show_title_bar = false %}
{% endif %}

