</div>
{% endcapture %}

{% capture immich_random_image_markup %}
<div class="layout layout--stretch">
  <img class="image image-dither image--contain" src="https://{{ immich_settings.immich_url }}/api/assets/{{ immich_asset.id }}/thumbnail?apiKey={{ immich_settings.api_key }}&amp;edited=true&amp;size=fullsize" alt="image">
</div>
{% if immich_show_title_bar %}
{{ immich_title_bar_markup }}
{% endif %}
{% endcapture %}
