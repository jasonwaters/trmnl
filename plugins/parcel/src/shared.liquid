{% assign parcel_instance_suffix = "parcel" | append_random %}
{% assign parcel_instance_key = parcel_instance_suffix %}
{% assign parcel_deliveries_container_id = "deliveries-container-" | append: parcel_instance_suffix %}
{% assign parcel_title_bar_id = "parcel-title-bar-" | append: parcel_instance_suffix %}
{% assign parcel_delivery_count_id = "delivery-count-" | append: parcel_instance_suffix %}
{% assign parcel_filter_label_id = "filter-label-" | append: parcel_instance_suffix %}
{% assign parcel_out_for_delivery_count_id = "out-for-delivery-count-" | append: parcel_instance_suffix %}

<script>
  (function() {
  const PARCEL_INSTANCE_KEY = {{ parcel_instance_key | json }};
  const PARCEL_USER_LOCALE = {{ trmnl.user.locale | default: "en-US" | json }};
  const PARCEL_RAW_UTC_OFFSET = {{ trmnl.user.utc_offset | default: 0 | plus: 0 }};
  const PARCEL_CURRENT_UTC_EPOCH = {{ trmnl.system.timestamp_utc | plus: 0 }};
  const PARCEL_FILTER_MODE = "{{ trmnl.plugin_settings.custom_fields_values.filter_mode | default: 'active' }}";
  const PARCEL_STYLE = "{{ trmnl.plugin_settings.custom_fields_values.style | default: 'detailed' }}";
  const PARCEL_SORT_BY = "{{ trmnl.plugin_settings.custom_fields_values.sort_by | default: 'estimated_delivery_date' }}";

  const PARCEL_DELIVERIES = [
    {% for d in deliveries %}
      {
        title: {{ d.description | json }},
        statusCode: {{ d.status_code }},
        events: {{ d.events | json }},
        dateExpected: {{ d.date_expected | json }},
        dateExpectedEnd: {{ d.date_expected_end | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  const PARCEL_STATUS_LABELS = {
    0: 'Delivered',
    1: 'Frozen',
    2: 'In Transit',
    3: 'Pickup Available',
    4: 'Out for Delivery',
    5: 'Not Found',
    6: 'Failed Attempt',
    7: 'Exception',
    8: 'Info Received'
  };

  function parcelNormalizeOffsetSeconds(rawOffset) {
    const abs = Math.abs(rawOffset);
    if (abs <= 24) return rawOffset * 3600;
    if (abs <= 840) return rawOffset * 60;
    return rawOffset;
  }

  const PARCEL_EFFECTIVE_UTC_OFFSET_SECONDS = parcelNormalizeOffsetSeconds(PARCEL_RAW_UTC_OFFSET);

  function parcelPad2(value) {
    return String(value).padStart(2, '0');
  }

  function parcelToLocalDateKey(epochSeconds) {
    const shifted = new Date((epochSeconds + PARCEL_EFFECTIVE_UTC_OFFSET_SECONDS) * 1000);
    return `${shifted.getUTCFullYear()}-${parcelPad2(shifted.getUTCMonth() + 1)}-${parcelPad2(shifted.getUTCDate())}`;
  }

  function parcelDateKeyToUtcDate(dateKey) {
    if (!dateKey) return null;
    const parts = String(dateKey).split('-');
    if (parts.length !== 3) return null;
    return new Date(Date.UTC(parseInt(parts[0], 10), parseInt(parts[1], 10) - 1, parseInt(parts[2], 10)));
  }

  function parcelParseInputToEpochSeconds(value) {
    if (!value) return null;
    const parsed = Date.parse(value);
    if (!Number.isNaN(parsed)) return Math.floor(parsed / 1000);
    const normalized = Date.parse(String(value).replace(' ', 'T'));
    if (!Number.isNaN(normalized)) return Math.floor(normalized / 1000);
    return null;
  }

  function parcelInputToLocalDateKey(value) {
    const epoch = parcelParseInputToEpochSeconds(value);
    if (epoch === null) return null;
    return parcelToLocalDateKey(epoch);
  }

  function parcelDiffDaysByDateKey(targetDateKey, startDateKey) {
    const left = parcelDateKeyToUtcDate(targetDateKey);
    const right = parcelDateKeyToUtcDate(startDateKey);
    if (!left || !right) return null;
    return Math.round((left - right) / (1000 * 60 * 60 * 24));
  }

  const PARCEL_TODAY_DATE_KEY = parcelToLocalDateKey(PARCEL_CURRENT_UTC_EPOCH);

  function parcelFormatDeliveryBy(dateExpected) {
    const expectedDateKey = parcelInputToLocalDateKey(dateExpected);
    if (!expectedDateKey) return null;

    const diffDays = parcelDiffDaysByDateKey(expectedDateKey, PARCEL_TODAY_DATE_KEY);
    if (diffDays === null || diffDays < 0) return null;
    if (diffDays === 0) return 'Today';
    if (diffDays === 1) return 'Tomorrow';

    const expectedDate = parcelDateKeyToUtcDate(expectedDateKey);
    if (!expectedDate) return null;
    if (diffDays < 7) {
      return expectedDate.toLocaleDateString(PARCEL_USER_LOCALE, { weekday: 'long', timeZone: 'UTC' });
    }
    return expectedDate.toLocaleDateString(PARCEL_USER_LOCALE, { month: 'short', day: 'numeric', timeZone: 'UTC' });
  }

  function parcelGetTransitDayCount(delivery) {
    var expectedDateValue = delivery.dateExpected || delivery.dateExpectedEnd;
    var expectedDateKey = parcelInputToLocalDateKey(expectedDateValue);
    if (!expectedDateKey) return null;

    var dayCount = parcelDiffDaysByDateKey(expectedDateKey, PARCEL_TODAY_DATE_KEY);
    if (dayCount === null || dayCount < 0) return 0;
    return dayCount;
  }

  function parcelMaterialSymbolIconMarkup(iconName, altText) {
    return `
      <img
        src="https://fonts.gstatic.com/s/i/short-term/release/materialsymbolsoutlined/${iconName}/default/24px.svg"
        class="no-shrink"
        style="width: 48px; height: 48px;"
        alt="${altText}"
      />
    `;
  }

  function parcelTransitIconMarkup(delivery) {
    var transitDays = parcelGetTransitDayCount(delivery);
    if (transitDays === null) {
      return parcelMaterialSymbolIconMarkup('local_shipping', 'In Transit');
    }
    if (transitDays > 9) {
      return parcelMaterialSymbolIconMarkup('timer', 'In Transit');
    }
    var counterValue = Math.max(0, Math.min(9, transitDays));
    return parcelMaterialSymbolIconMarkup(`counter_${counterValue}`, `In Transit: ${counterValue} days`);
  }

  function parcelStatusIconMarkup(delivery) {
    var statusCode = delivery.statusCode;
    if (statusCode === 0) return parcelMaterialSymbolIconMarkup('check_circle', 'Delivered');
    if (statusCode === 1) return parcelMaterialSymbolIconMarkup('ac_unit', 'Frozen');
    if (statusCode === 2 || statusCode === 4) return parcelTransitIconMarkup(delivery);
    if (statusCode === 3) return parcelMaterialSymbolIconMarkup('airport_shuttle', 'Pickup Available');
    if (statusCode === 5 || statusCode === 8) return parcelMaterialSymbolIconMarkup('question_mark', 'Status Unknown');
    if (statusCode === 6 || statusCode === 7) return parcelMaterialSymbolIconMarkup('priority_high', 'Delivery Exception');
    return parcelMaterialSymbolIconMarkup('question_mark', 'Status Unknown');
  }

  function parcelRenderLeadingContent(delivery) {
    return `
      <div class="icon no-shrink flex flex--center-x" style="width: 54px; min-width: 54px;">
        ${parcelStatusIconMarkup(delivery)}
      </div>
    `;
  }

  function parcelGetEmphasisClass(delivery) {
    if (delivery.statusCode === 4) return 'item--emphasis-3';
    if (delivery.statusCode === 0) return 'item--emphasis-1';

    const daysUntil = parcelDiffDaysByDateKey(parcelInputToLocalDateKey(delivery.dateExpected), PARCEL_TODAY_DATE_KEY);
    if (daysUntil === null) return 'item--emphasis-1';
    if (daysUntil <= 0) return 'item--emphasis-3';
    if (daysUntil <= 2) return 'item--emphasis-2';
    return 'item--emphasis-1';
  }

  function parcelIsDeliveredStatus(statusCode) {
    return statusCode === 0;
  }

  function parcelGetLatestEventEpoch(delivery) {
    if (!delivery.events || !delivery.events.length) return null;
    return parcelParseInputToEpochSeconds(delivery.events[0].date);
  }

  function parcelGetOldestEventEpoch(delivery) {
    if (!delivery.events || !delivery.events.length) return null;
    return parcelParseInputToEpochSeconds(delivery.events[delivery.events.length - 1].date);
  }

  function parcelGetExpectedEpoch(delivery) {
    return parcelParseInputToEpochSeconds(delivery.dateExpected);
  }

  function parcelSortByEstimatedDeliveryDate(left, right) {
    var leftDelivered = parcelIsDeliveredStatus(left.statusCode);
    var rightDelivered = parcelIsDeliveredStatus(right.statusCode);
    if (leftDelivered !== rightDelivered) return leftDelivered ? 1 : -1;

    var leftExpected = parcelGetExpectedEpoch(left);
    var rightExpected = parcelGetExpectedEpoch(right);
    var leftHasExpected = Number.isFinite(leftExpected);
    var rightHasExpected = Number.isFinite(rightExpected);

    if (leftHasExpected !== rightHasExpected) return leftHasExpected ? -1 : 1;
    if (leftHasExpected && rightHasExpected && leftExpected !== rightExpected) {
      return leftExpected - rightExpected;
    }

    var leftLatest = parcelGetLatestEventEpoch(left);
    var rightLatest = parcelGetLatestEventEpoch(right);
    if (Number.isFinite(leftLatest) && Number.isFinite(rightLatest) && leftLatest !== rightLatest) {
      return rightLatest - leftLatest;
    }

    return String(left.title || '').localeCompare(String(right.title || ''), PARCEL_USER_LOCALE);
  }

  function parcelSortDeliveries(deliveries) {
    var sorted = deliveries.slice();

    if (PARCEL_SORT_BY === 'name') {
      sorted.sort(function(left, right) {
        return String(left.title || '').localeCompare(String(right.title || ''), PARCEL_USER_LOCALE);
      });
      return sorted;
    }

    if (PARCEL_SORT_BY === 'last_updated') {
      sorted.sort(function(left, right) {
        var leftLatest = parcelGetLatestEventEpoch(left);
        var rightLatest = parcelGetLatestEventEpoch(right);
        if (!Number.isFinite(leftLatest) && !Number.isFinite(rightLatest)) return 0;
        if (!Number.isFinite(leftLatest)) return 1;
        if (!Number.isFinite(rightLatest)) return -1;
        return rightLatest - leftLatest;
      });
      return sorted;
    }

    if (PARCEL_SORT_BY === 'date_added') {
      sorted.sort(function(left, right) {
        var leftOldest = parcelGetOldestEventEpoch(left);
        var rightOldest = parcelGetOldestEventEpoch(right);
        if (!Number.isFinite(leftOldest) && !Number.isFinite(rightOldest)) return 0;
        if (!Number.isFinite(leftOldest)) return 1;
        if (!Number.isFinite(rightOldest)) return -1;
        return leftOldest - rightOldest;
      });
      return sorted;
    }

    sorted.sort(parcelSortByEstimatedDeliveryDate);
    return sorted;
  }

  function parcelRenderDelivery(delivery, style) {
    const statusLabel = PARCEL_STATUS_LABELS[delivery.statusCode] || 'Unknown';
    const latestEvent = delivery.events && delivery.events.length > 0 ? delivery.events[0].event : null;
    const deliveryBy = parcelFormatDeliveryBy(delivery.dateExpected);
    const emphasisClass = parcelGetEmphasisClass(delivery);

    if (style === 'compact') {
      return `
        <div class="item ${emphasisClass}">
          <div class="meta"></div>
          ${parcelRenderLeadingContent(delivery)}
          <div class="content">
            <div class="flex flex--row">
              <span class="title title--small">${delivery.title}</span>
              <span class="label label--small label--inverted no-shrink">${statusLabel}</span>
            </div>
            <div class="description">
              ${latestEvent ? `<div class="label label--small clamp--2">${latestEvent}</div>` : ''}
              ${deliveryBy ? `<div class="label label--small clamp--2">Delivery by: ${deliveryBy}</div>` : ''}
            </div>
          </div>
        </div>`;
    }

    return `
      <div class="item ${emphasisClass}">
        <div class="meta"></div>
        ${parcelRenderLeadingContent(delivery)}
        <div class="content">
          <span class="title title--small">${delivery.title}</span>
          ${latestEvent ? `<div class="label label--small clamp--2">${latestEvent}</div>` : ''}
          <div class="flex gap--small">
            <span class="label label--small label--inverted">${statusLabel}</span>
            ${deliveryBy ? `<span class="label label--small label--underline">Delivery by: ${deliveryBy}</span>` : ''}
          </div>
        </div>
      </div>`;
  }

  function parcelFilterLabelText(filterMode) {
    const labels = {
      all: 'All Deliveries',
      active: 'Active Deliveries',
      recent: 'Recent Deliveries',
      delivered: 'Completed Deliveries'
    };
    return labels[filterMode] || 'Deliveries';
  }

  function parcelTitleBarMarkup(instanceText) {
    var instance = instanceText || '';
    return `
      <div class="title_bar">
        <img class="image" src="https://usetrmnl.com/images/plugins/parcel--render.png"/>
        <h1 class="title">Parcel</h1>
        <span class="instance">${instance}</span>
      </div>
    `;
  }

  function initializeParcelTitleBar(options) {
    var settings = options || {};
    var titleBarElement = document.getElementById(settings.targetId || 'parcel-title-bar');
    if (!titleBarElement) return;
    titleBarElement.outerHTML = parcelTitleBarMarkup(settings.instanceText || '');
  }

  function initializeParcelTemplate(options) {
    const settings = options || {};
    const style = settings.style || PARCEL_STYLE;
    const container = document.getElementById(settings.containerId || 'deliveries-container');
    const listHeightSafetyBufferPx = Number.isFinite(settings.listHeightSafetyBufferPx)
      ? settings.listHeightSafetyBufferPx
      : 4;

    if (settings.showSummary) {
      const outForDelivery = PARCEL_DELIVERIES.filter(function(delivery) {
        return delivery.statusCode === 4;
      }).length;
      const outForDeliveryElement = document.getElementById(settings.outForDeliveryId || 'out-for-delivery-count');
      if (outForDeliveryElement) outForDeliveryElement.textContent = outForDelivery;

      const filterLabelElement = document.getElementById(settings.filterLabelId || 'filter-label');
      if (filterLabelElement) filterLabelElement.textContent = parcelFilterLabelText(PARCEL_FILTER_MODE);
    }

    if (!container || PARCEL_DELIVERIES.length === 0) return;

    // Framework best practice: size list-limit from actual rendered container space,
    // not from hard-coded heights or device metadata.
    var measuredMaxHeight = null;
    var layoutElement = container.closest('.layout');
    if (layoutElement) {
      var layoutRect = layoutElement.getBoundingClientRect();
      var containerRect = container.getBoundingClientRect();
      var spaceUsedAboveList = Math.max(0, containerRect.top - layoutRect.top);
      var remainingHeightInLayout = Math.floor(layoutRect.height - spaceUsedAboveList);
      if (remainingHeightInLayout > 0) measuredMaxHeight = remainingHeightInLayout;
    }
    if (!Number.isFinite(measuredMaxHeight)) {
      measuredMaxHeight = parseInt(container.getAttribute('data-list-max-height'), 10);
    }
    if (Number.isFinite(measuredMaxHeight) && measuredMaxHeight > listHeightSafetyBufferPx) {
      container.setAttribute('data-list-max-height', String(measuredMaxHeight - listHeightSafetyBufferPx));
    }

    var sortedDeliveries = parcelSortDeliveries(PARCEL_DELIVERIES);
    container.innerHTML = sortedDeliveries.map(function(delivery) {
      return parcelRenderDelivery(delivery, style);
    }).join('');

    // Nudge any framework list limiter that listens to resize/reflow.
    requestAnimationFrame(function() {
      window.dispatchEvent(new Event('resize'));
    });
  }
  window.__parcelInstances = window.__parcelInstances || {};
  window.__parcelInstances[PARCEL_INSTANCE_KEY] = {
    initializeTitleBar: initializeParcelTitleBar,
    initializeTemplate: initializeParcelTemplate
  };
  })();
</script>
