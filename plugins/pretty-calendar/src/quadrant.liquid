<div class="layout layout--col layout--top p--2 gap--none">

  {% comment %} === HEADER: Month & Year === {% endcomment %}
  <div class="flex flex--row w--full value--small flex--left flex--center-y p--2 mb--4 lg:mb--20">
    <div class="">{{ current_month }}</div>
    <div class="text--gray-30">{{ year }}</div>
  </div>

  {% comment %} === DAY NAMES BAR === {% endcomment %}
  <div class="grid grid--cols-7 gap--1 w--full mb--1">
    {% for i in (0..6) %}
    {% assign day_index = first_day | plus: i | modulo: 7 %}
    {% assign day_label = day_names_short[day_index] %}
    <div class="col--span-1 text--center text--gray-30 flex flex--row flex--center-x">
      {{ day_label }}
    </div>
    {% endfor %}
  </div>

  {% comment %} === CALENDAR DAYS WITH DOTS === {% endcomment %}
  <div class="grid grid--cols-7 gap--2 w--full pb--5">
    {% for day_data in days_data %}
    {% assign day_parts = day_data | split: "|" %}
    {% assign date = day_parts[0] %}
    {% assign day_num = day_parts[1] %}
    {% assign day_name = day_parts[2] %}
    {% assign day_short = day_parts[3] %}
    {% assign month_name = day_parts[4] %}
    {% assign event_count = day_parts[5] | plus: 0 %}
    {% assign is_today = day_parts[6] %}

    {% comment %} Limit dots to max 4 {% endcomment %}
    {% if event_count > 4 %}
    {% assign event_count = 4 %}
    {% endif %}

    <div class="col--span-1 flex flex--col">
      <div class="rounded--full text--center aspect--1/1 h--12 {% if is_today == 'true' %}text--white{% elsif date < current_date %}text--gray-40{% endif %}"{% if is_today == 'true' %} style="background-color:#000;"{% endif %}>
        <div class="value--small pt--2 pb--0.5">{{ day_num }}</div>

        {% if is_today == 'true' %}
          <div class="flex flex--row flex--center-x gap--xsmall" style="position: relative; top: {{ calendar_today_dot_offset_px }}px;">
            <div class="{{ calendar_day_dot_size_class }} rounded--full bg--white"></div>
            <div class="{{ calendar_day_dot_size_class }} rounded--full bg--white"></div>
            <div class="{{ calendar_day_dot_size_class }} rounded--full bg--white"></div>
          </div>
        {% elsif event_count > 0 %}
          <div class="flex flex--row flex--center-x gap--xsmall">
            {% for dot in (1..event_count) %}
            <div class="{{ calendar_day_dot_size_class }} rounded--full bg--gray-30"></div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>

</div>