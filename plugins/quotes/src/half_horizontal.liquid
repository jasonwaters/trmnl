<div class="layout layout--col layout--center">
  <div class="w--full h--full flex flex--col flex--center-y flex--center-x text--center p--1">
    <div class="icon mb--1">
      <div class="text--gray-3">
        {{ quote_icon_markup }}
      </div>
    </div>
    <span class="value value--medium quote-serif" data-value-fit="true" data-value-fit-max-height="72">
      <span id="{{ quote_text_id }}">Loading quote…</span>
    </span>
    <div class="label label--small text--gray-4 mt--1 quote-attribution">
      <span id="{{ quote_author_id }}">Author</span>
    </div>
  </div>
</div>

<script type="text/javascript">
  try {
    window.sheetQuotePlugin.renderQuote({
      payload: {{ data | default: "" | json }},
      quoteSelector: {{ "#" | append: quote_text_id | json }},
      authorSelector: {{ "#" | append: quote_author_id | json }},
      quoteIndex: {{ trmnl.plugin_settings.custom_fields_values.quote_index | plus: 0 }},
      authorIndex: {{ trmnl.plugin_settings.custom_fields_values.author_index | plus: 0 }},
      selectionMode: {{ trmnl.plugin_settings.custom_fields_values.quote_selection_mode | default: "random" | json }},
      specificQuoteRow: {{ trmnl.plugin_settings.custom_fields_values.specific_quote_row | default: 1 | plus: 0 }}
    });
  } catch (error) {
    console.error("Sheet Quote: Critical Error", error);
    document.querySelector({{ "#" | append: quote_text_id | json }}).textContent = "Error: " + error.message;
    document.querySelector({{ "#" | append: quote_author_id | json }}).textContent = "";
  }
</script>
